---
import type { Locale } from '../i18n/utils';
import { localized } from '../lib/content';
import { localePath, t } from '../i18n/utils';

interface Props {
  locale: Locale;
  slug: string;
  entry: Record<string, any>;
}

const { locale, slug, entry } = Astro.props;
const strings = t(locale);
const title = localized(entry, 'title', locale);
const manifest = entry.photo_manifest ? JSON.parse(entry.photo_manifest) : [];
const dateStr = new Date(entry.date).toLocaleDateString(
  locale === 'en' ? 'en-CA' : locale === 'zh-tw' ? 'zh-TW' : 'zh-CN',
  { year: 'numeric', month: 'long', day: 'numeric' },
);
---

<a
  href={localePath(locale, `/gallery/${slug}`)}
  class="group block bg-white rounded-2xl border border-porcelain-border overflow-hidden hover:shadow-[0_4px_20px_rgba(0,0,0,0.06)] hover:-translate-y-0.5 transition-all"
>
  {entry.cover_image ? (
    <div class="h-56 bg-porcelain-section overflow-hidden">
      <img
        src={entry.cover_image}
        alt={title}
        loading="lazy"
        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300"
      />
    </div>
  ) : (
    <div class="h-56 bg-porcelain-section flex items-center justify-center text-porcelain-tertiary text-4xl">
      📷
    </div>
  )}
  <div class="p-5">
    <h3 class="font-display text-[1.05rem] font-semibold text-porcelain-text leading-snug">{title}</h3>
    <p class="text-[0.82rem] text-porcelain-tertiary mt-1">
      {dateStr} · {manifest.length} {strings.gallery.photos}
    </p>
  </div>
</a>
