---
/**
 * Elegant typographic page header for interior pages.
 * Replaces the plain <h1> with a branded, consistent header treatment.
 */
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="page-header pt-14 pb-10 px-8">
  <div class="max-w-[1080px] mx-auto">
    <h1 class="font-display text-3xl md:text-[2.2rem] font-semibold tracking-tight text-porcelain-text">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-2 text-porcelain-secondary text-[0.95rem] max-w-[520px]">{subtitle}</p>
    )}
    <div class="mt-5 h-[2px] w-12 bg-accent/30 rounded-full" />
  </div>
</div>
