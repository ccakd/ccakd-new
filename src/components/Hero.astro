---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
  heading: string;
  ctaLink: string;
  images: string[];
}

const { locale, heading, ctaLink, images } = Astro.props;
const strings = t(locale);

const defaultImages = [
  '/images/hero/DH0A9921.webp',
  '/images/hero/DH0A8079.webp',
  '/images/hero/DH0A8147.webp',
  '/images/hero/DH0A9712.webp',
  '/images/hero/DSC09300.webp',
];
const heroImages = images.length > 0 ? images : defaultImages;
---

<section class="hero-section relative h-[360px] md:h-[480px] overflow-hidden bg-black">
  <div class="hero-track flex h-full">
    {heroImages.map((src) => (
      <div
        class="hero-slide min-w-full h-full bg-cover bg-center relative"
        style={`background-image:url('${src}')`}
      >
        <div class="absolute inset-0 hero-gradient" />
      </div>
    ))}
  </div>
  <div class="absolute bottom-0 left-0 right-0 z-10 max-w-[1080px] mx-auto px-8 pb-10 md:pb-14 text-white">
    <h1 class="font-display text-3xl md:text-[2.8rem] font-semibold leading-tight max-w-[520px] tracking-tight hero-heading">
      {heading}
    </h1>
    <p class="text-sm md:text-base opacity-95 font-light mt-2 max-w-[420px] hero-subtitle">
      {strings.home.heroSubtitle}
    </p>
    <a
      href={ctaLink}
      class="inline-block mt-5 px-6 py-2.5 bg-white text-porcelain-text rounded-pill font-medium text-sm hover:bg-white/90 transition-all shadow-md"
    >
      {strings.home.becomeMember} &rarr;
    </a>
  </div>
  <div class="absolute bottom-5 left-1/2 -translate-x-1/2 z-10 flex gap-1.5">
    {heroImages.map((_, i) => (
      <span class:list={[
        'hero-dot block h-1.5 rounded-full transition-all duration-300',
        i === 0 ? 'w-5 bg-white/85' : 'w-1.5 bg-white/35',
      ]} />
    ))}
  </div>
</section>

<script>
  const track = document.querySelector('.hero-track') as HTMLElement;
  const dots = document.querySelectorAll('.hero-dot');
  if (track) {
    const slides = track.children.length;
    let current = 0;
    function advance() {
      current = (current + 1) % slides;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((dot, i) => {
        dot.classList.toggle('w-5', i === current);
        dot.classList.toggle('bg-white/85', i === current);
        dot.classList.toggle('w-1.5', i !== current);
        dot.classList.toggle('bg-white/35', i !== current);
      });
    }
    setInterval(advance, 5000);
  }
</script>

<style>
  .hero-track {
    transition: transform 0.8s ease-in-out;
  }
  .hero-gradient {
    background: linear-gradient(
      to bottom,
      transparent 20%,
      rgba(0,0,0,0.1) 35%,
      rgba(0,0,0,0.4) 60%,
      rgba(0,0,0,0.72) 85%,
      rgba(0,0,0,0.8) 100%
    );
  }
  .hero-heading {
    text-shadow:
      0 1px 3px rgba(0,0,0,0.5),
      0 4px 16px rgba(0,0,0,0.3);
  }
  .hero-subtitle {
    text-shadow:
      0 1px 2px rgba(0,0,0,0.6),
      0 2px 8px rgba(0,0,0,0.4);
  }
</style>
