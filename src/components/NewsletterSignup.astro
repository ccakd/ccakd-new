---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
---

<section class="py-16 px-8">
  <div class="max-w-[1080px] mx-auto">
    <div class="bg-porcelain-section rounded-[20px] py-14 px-8 text-center">
      <h2 class="font-display text-2xl font-semibold text-porcelain-text">{strings.home.newsletter}</h2>
      <p class="text-porcelain-secondary text-sm mt-1.5">{strings.home.newsletterDesc}</p>
      <form
        method="post"
        action="https://lists.ccakd.ca/subscription/form"
        class="listmonk-form mt-6 flex flex-col items-center gap-3 max-w-[400px] mx-auto"
      >
        <input type="hidden" name="nonce" />
        <input
          type="email"
          name="email"
          placeholder={strings.home.emailPlaceholder}
          required
          class="w-full px-5 py-2.5 border border-porcelain-border rounded-pill text-sm font-[inherit] text-porcelain-text bg-white focus:outline-none focus:border-accent"
        />
        <input type="hidden" name="l" value="b3b5823a-20b2-43a7-b51d-8056fc336dfb" />
        <div class="newsletter-altcha">
          <altcha-widget challengeurl="https://lists.ccakd.ca/api/public/captcha/altcha"></altcha-widget>
        </div>
        <button
          type="submit"
          class="w-full sm:w-auto px-7 py-2.5 bg-accent text-white border-none rounded-pill font-medium text-sm cursor-pointer font-[inherit] hover:bg-accent-hover transition-colors"
        >
          {strings.home.subscribe}
        </button>
      </form>
      <script is:inline src="https://lists.ccakd.ca/public/static/altcha.umd.js" async defer></script>
    </div>
  </div>
</section>
