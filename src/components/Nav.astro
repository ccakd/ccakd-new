---
import type { Locale } from '../i18n/utils';
import { t, localePath } from '../i18n/utils';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const strings = t(locale);

const navItems = [
  { label: strings.nav.home, path: '/' },
  { label: strings.nav.events, path: '/events' },
  { label: strings.nav.programs, path: '/programs' },
  { label: strings.nav.gallery, path: '/gallery' },
  { label: strings.nav.about, path: '/about' },
];

const localeLabels: { code: Locale; label: string }[] = [
  { code: 'en', label: 'EN' },
  { code: 'zh', label: '简体' },
  { code: 'zh-tw', label: '繁體' },
];
---

{/* Top bar */}
<div class="border-b border-porcelain-border text-[0.78rem] py-1 bg-white">
  <div class="max-w-[1080px] mx-auto px-8 flex justify-end items-center gap-3">
    <a href="https://members.ccakd.ca/en/login" class="text-porcelain-tertiary hover:text-porcelain-text transition-colors">{strings.nav.login}</a>
    <a href="https://members.ccakd.ca/en/register" class="text-porcelain-tertiary hover:text-porcelain-text transition-colors">{strings.nav.signup}</a>
    <div class="flex gap-0.5 ml-3">
      {localeLabels.map(({ code, label }) => (
        <a
          href={localePath(code, currentPath)}
          class:list={[
            'px-2.5 py-0.5 rounded-pill text-[0.72rem] font-medium transition-all',
            code === locale
              ? 'bg-porcelain-text text-white'
              : 'text-porcelain-tertiary hover:bg-porcelain-section',
          ]}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</div>

{/* Frosted glass nav */}
<nav class="sticky top-0 z-50 bg-white/85 backdrop-blur-[20px] backdrop-saturate-[180%] border-b border-black/[0.06]">
  <div class="max-w-[1080px] mx-auto px-8 flex items-center justify-between h-[52px]">
    <a href={localePath(locale, '/')} class="flex items-center gap-2">
      <img src="https://lists.ccakd.ca/uploads/ccakd_logo_100.png" alt="CCAKD" class="h-8" />
    </a>

    {/* Desktop nav - pill style */}
    <div class="hidden md:flex items-center gap-1">
      {navItems.map(({ label, path }) => (
        <a
          href={localePath(locale, path)}
          class:list={[
            'px-3.5 py-1.5 rounded-pill text-[0.84rem] transition-all',
            currentPath === path
              ? 'bg-accent-bg text-accent font-medium'
              : 'text-porcelain-secondary hover:bg-porcelain-section hover:text-porcelain-text',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="https://members.ccakd.ca/en/"
        class="px-3.5 py-1.5 rounded-pill text-[0.84rem] text-porcelain-secondary hover:bg-porcelain-section hover:text-porcelain-text transition-all"
        target="_blank"
      >
        {strings.nav.membership}
      </a>
    </div>

    {/* Mobile hamburger */}
    <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>

    {/* Mobile menu dropdown */}
    <div class="hidden peer-checked:flex absolute top-full left-0 right-0 bg-white shadow-lg flex-col md:hidden border-t border-porcelain-border">
      {navItems.map(({ label, path }) => (
        <a
          href={localePath(locale, path)}
          class:list={[
            'px-6 py-3 text-sm border-b border-porcelain-border/50',
            currentPath === path
              ? 'text-accent bg-accent-bg/50 font-medium'
              : 'text-porcelain-text hover:bg-porcelain-section',
          ]}
        >
          {label}
        </a>
      ))}
      <a href="https://members.ccakd.ca/en/" class="px-6 py-3 text-sm text-porcelain-text hover:bg-porcelain-section" target="_blank">
        {strings.nav.membership}
      </a>
    </div>
  </div>
</nav>
