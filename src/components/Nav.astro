---
import type { Locale } from '../i18n/utils';
import { t, localePath } from '../i18n/utils';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const strings = t(locale);

const navItems = [
  { label: strings.nav.home, path: '/' },
  { label: strings.nav.events, path: '/events' },
  { label: strings.nav.programs, path: '/programs' },
  { label: strings.nav.gallery, path: '/gallery' },
  { label: strings.nav.about, path: '/about' },
];

const localeLabels: { code: Locale; label: string }[] = [
  { code: 'en', label: 'EN' },
  { code: 'zh', label: '简体' },
  { code: 'zh-tw', label: '繁體' },
];
---

{/* Top bar */}
<div data-topbar class="relative z-50 border-b border-white/10 text-[0.78rem] py-1 transition-all duration-300">
  <div class="max-w-[1080px] mx-auto px-8 flex justify-end items-center gap-3">
    <a href="https://members.ccakd.ca/en/login" class="text-white/60 hover:text-white/90 transition-colors">{strings.nav.login}</a>
    <a href="https://members.ccakd.ca/en/register" class="text-white/60 hover:text-white/90 transition-colors">{strings.nav.signup}</a>
    <div class="flex gap-0.5 ml-3">
      {localeLabels.map(({ code, label }) => (
        <a
          href={localePath(code, currentPath)}
          class:list={[
            'px-2.5 py-0.5 rounded-pill text-[0.72rem] font-medium transition-all',
            code === locale ? 'lang-active bg-white/90 text-porcelain-text' : 'lang-inactive text-white/60 hover:bg-white/15',
          ]}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</div>

{/* Frosted glass nav — overlays hero for color bleed-through */}
<nav class="sticky top-0 z-50 nav-frost border-b border-white/[0.12]">
  <div class="max-w-[1080px] mx-auto px-8 flex items-center justify-between h-[58px]">
    <a href={localePath(locale, '/')} class="flex items-center gap-3 min-w-0 group">
      <img src="https://lists.ccakd.ca/uploads/ccakd_logo_100.png" alt="CCAKD" class="nav-logo-img h-10 shrink-0 drop-shadow-sm" />
      <span class="nav-mobile-name sm:hidden font-display text-[1.05rem] font-semibold text-white tracking-[-0.01em] drop-shadow-sm">CCAKD</span>
      <div class="hidden sm:flex flex-col justify-center min-w-0">
        <span class="nav-logo-title font-display text-[0.92rem] font-semibold leading-[1.2] text-white tracking-[-0.01em] drop-shadow-sm">
          {locale === 'zh' ? '京士顿区华人协会' : locale === 'zh-tw' ? '京士頓區華人協會' : 'Chinese Canadian Association'}
        </span>
        <span class="nav-logo-sub text-[0.68rem] text-white/70 leading-tight tracking-[0.02em] drop-shadow-sm">
          {locale === 'zh' ? 'Chinese Canadian Assn. of Kingston & District' : locale === 'zh-tw' ? 'Chinese Canadian Assn. of Kingston & District' : 'of Kingston & District'}
        </span>
      </div>
    </a>

    {/* Desktop nav - pill style */}
    <div class="hidden md:flex items-center gap-1">
      {navItems.map(({ label, path }) => (
        <a
          href={localePath(locale, path)}
          class:list={[
            'nav-link px-3.5 py-1.5 rounded-pill text-[0.84rem]',
            currentPath === path ? 'nav-link-active bg-white/20 text-white font-medium' : 'text-white/75 hover:bg-white/10 hover:text-white',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="https://members.ccakd.ca/en/"
        class="nav-link px-3.5 py-1.5 rounded-pill text-[0.84rem] text-white/75 hover:bg-white/10 hover:text-white"
        target="_blank"
      >
        {strings.nav.membership}
      </a>
    </div>

    {/* Mobile hamburger */}
    <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
    <label for="mobile-menu-toggle" class="nav-mobile-label md:hidden cursor-pointer p-2 text-white">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>

    {/* Mobile menu dropdown */}
    <div class="hidden peer-checked:flex absolute top-full left-0 right-0 bg-white shadow-lg flex-col md:hidden border-t border-porcelain-border">
      {navItems.map(({ label, path }) => (
        <a
          href={localePath(locale, path)}
          class:list={[
            'px-6 py-3 text-sm border-b border-porcelain-border/50',
            currentPath === path
              ? 'text-accent bg-accent-bg/50 font-medium'
              : 'text-porcelain-text hover:bg-porcelain-section',
          ]}
        >
          {label}
        </a>
      ))}
      <a href="https://members.ccakd.ca/en/" class="px-6 py-3 text-sm text-porcelain-text hover:bg-porcelain-section" target="_blank">
        {strings.nav.membership}
      </a>
    </div>
  </div>
</nav>

<style>
  .nav-frost {
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: saturate(180%) blur(24px);
    -webkit-backdrop-filter: saturate(180%) blur(24px);
    transition: background 0.35s ease, border-color 0.35s ease;
  }
  .nav-frost.nav-scrolled {
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom-color: rgba(0, 0, 0, 0.06) !important;
  }
  /* Color transitions for all nav text elements */
  .nav-frost :is(a, span, label) {
    transition: color 0.35s ease, background-color 0.35s ease;
  }

  /* Scrolled / no-hero light mode overrides */
  :global(html.nav-light) .nav-link { color: #6E6E73; }
  :global(html.nav-light) .nav-link:hover { background: #F5F5F7; color: #1D1D1F; }
  :global(html.nav-light) .nav-link-active { background: #FEF2F0; color: #D04830; }
  :global(html.nav-light) .nav-logo-title { color: #1D1D1F; filter: none; }
  :global(html.nav-light) .nav-logo-title:hover { color: #D04830; }
  :global(html.nav-light) .nav-logo-sub { color: #999; filter: none; }
  :global(html.nav-light) .nav-mobile-label { color: #1D1D1F; }
  :global(html.nav-light) .nav-mobile-name { color: #1D1D1F; filter: none; }
  :global(html.nav-light) .nav-logo-img { filter: none; }

  /* Top bar light mode */
  .topbar-light { background: white; border-bottom-color: #E8E8ED !important; }
  .topbar-light a { color: #999 !important; }
  .topbar-light a:hover { color: #1D1D1F !important; }
  .topbar-light .lang-active { background: #1D1D1F !important; color: white !important; }
  .topbar-light .lang-inactive { color: #999 !important; }
  .topbar-light .lang-inactive:hover { background: #F5F5F7 !important; }
</style>

<script>
  const nav = document.querySelector('.nav-frost') as HTMLElement;
  const topbar = document.querySelector('[data-topbar]') as HTMLElement;
  if (nav) {
    const heroEl = document.querySelector('.hero-section') as HTMLElement;
    // No hero = immediately scrolled (light) mode
    if (!heroEl) {
      nav.classList.add('nav-scrolled');
      document.documentElement.classList.add('nav-light');
      if (topbar) topbar.classList.add('topbar-light');
    } else {
      const threshold = heroEl.offsetHeight - 120;
      function updateNav() {
        const scrolled = window.scrollY > threshold;
        nav.classList.toggle('nav-scrolled', scrolled);
        document.documentElement.classList.toggle('nav-light', scrolled);
        if (topbar) topbar.classList.toggle('topbar-light', scrolled);
      }
      window.addEventListener('scroll', updateNav, { passive: true });
      updateNav();
    }
  }
</script>
