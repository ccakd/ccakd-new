---
import type { Locale } from '../i18n/utils';
import { t, localePath } from '../i18n/utils';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const strings = t(locale);

const navItems = [
  { label: strings.nav.home, path: '/' },
  { label: strings.nav.events, path: '/events' },
  { label: strings.nav.programs, path: '/programs' },
  { label: strings.nav.gallery, path: '/gallery' },
  { label: strings.nav.about, path: '/about' },
];

const localeLabels: { code: Locale; label: string }[] = [
  { code: 'en', label: 'EN' },
  { code: 'zh', label: '简体' },
  { code: 'zh-tw', label: '繁體' },
];
---

{/* Utility top bar — thin, solid, clearly separate */}
<div data-topbar class="topbar-strip border-b border-[#E8E8ED] text-[0.74rem] py-[3px]">
  <div class="max-w-[1080px] mx-auto px-8 flex justify-end items-center gap-3">
    <a href="https://members.ccakd.ca/en/login" class="text-[#999] hover:text-[#1D1D1F] transition-colors">{strings.nav.login}</a>
    <a href="https://members.ccakd.ca/en/register" class="text-[#999] hover:text-[#1D1D1F] transition-colors">{strings.nav.signup}</a>
    <div class="flex gap-0.5 ml-3">
      {localeLabels.map(({ code, label }) => (
        <a
          href={localePath(code, currentPath)}
          class:list={[
            'px-2.5 py-0.5 rounded-pill text-[0.7rem] font-medium transition-all',
            code === locale ? 'bg-[#1D1D1F] text-white' : 'text-[#999] hover:bg-[#F5F5F7]',
          ]}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</div>

{/* Main nav — white frosted glass, hero colors bleed through on scroll */}
<nav class="nav-frost sticky top-0 z-50 border-b border-[rgba(0,0,0,0.06)]">
  <div class="max-w-[1080px] mx-auto px-8 flex items-center justify-between h-[58px]">
    <a href={localePath(locale, '/')} class="flex items-center gap-3 min-w-0 group">
      <img src="https://lists.ccakd.ca/uploads/ccakd_logo_100.png" alt="CCAKD" class="h-10 shrink-0 drop-shadow-sm" />
      <span class="sm:hidden font-display text-[1.05rem] font-semibold text-[#1D1D1F] tracking-[-0.01em]">CCAKD</span>
      <div class="hidden sm:flex flex-col justify-center min-w-0">
        <span class="font-display text-[0.92rem] font-semibold leading-[1.2] text-[#1D1D1F] tracking-[-0.01em] group-hover:text-accent transition-colors">
          {locale === 'zh' ? '京士顿区华人协会' : locale === 'zh-tw' ? '京士頓區華人協會' : 'Chinese Canadian Association'}
        </span>
        <span class="text-[0.68rem] text-[#999] leading-tight tracking-[0.02em]">
          {locale === 'zh' ? 'Chinese Canadian Assn. of Kingston & District' : locale === 'zh-tw' ? 'Chinese Canadian Assn. of Kingston & District' : 'of Kingston & District'}
        </span>
      </div>
    </a>

    {/* Desktop nav - pill style */}
    <div class="hidden md:flex items-center gap-1">
      {navItems.map(({ label, path }) => (
        <a
          href={localePath(locale, path)}
          class:list={[
            'nav-pill px-3.5 py-1.5 rounded-pill text-[0.84rem] transition-all',
            currentPath === path ? 'bg-accent-bg text-accent font-medium' : 'text-[#6E6E73] hover:bg-[#F5F5F7] hover:text-[#1D1D1F]',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="https://members.ccakd.ca/en/"
        class="nav-pill px-3.5 py-1.5 rounded-pill text-[0.84rem] text-[#6E6E73] hover:bg-[#F5F5F7] hover:text-[#1D1D1F] transition-all"
        target="_blank"
      >
        {strings.nav.membership}
      </a>
    </div>

    {/* Mobile hamburger */}
    <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 text-[#1D1D1F]">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>

    {/* Mobile menu dropdown */}
    <div class="hidden peer-checked:flex absolute top-full left-0 right-0 bg-white shadow-lg flex-col md:hidden border-t border-porcelain-border">
      {navItems.map(({ label, path }) => (
        <a
          href={localePath(locale, path)}
          class:list={[
            'px-6 py-3 text-sm border-b border-porcelain-border/50',
            currentPath === path
              ? 'text-accent bg-accent-bg/50 font-medium'
              : 'text-porcelain-text hover:bg-porcelain-section',
          ]}
        >
          {label}
        </a>
      ))}
      <a href="https://members.ccakd.ca/en/" class="px-6 py-3 text-sm text-porcelain-text hover:bg-porcelain-section" target="_blank">
        {strings.nav.membership}
      </a>
    </div>
  </div>
</nav>

<style>
  /* Utility bar — solid, always opaque */
  .topbar-strip {
    background: #FAFAFA;
  }

  /* Nav — white frosted glass, lets hero colors bleed through */
  .nav-frost {
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    transition: background 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
  }

  /* When scrolled past hero — more opaque, subtle shadow */
  .nav-frost.nav-solid {
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.04);
    border-bottom-color: rgba(0, 0, 0, 0.08);
  }
</style>

<script>
  const nav = document.querySelector('.nav-frost') as HTMLElement;
  if (nav) {
    const heroEl = document.querySelector('.hero-section') as HTMLElement;
    if (!heroEl) {
      // No hero — solid nav immediately
      nav.classList.add('nav-solid');
    } else {
      const threshold = heroEl.offsetHeight;
      function updateNav() {
        nav.classList.toggle('nav-solid', window.scrollY > threshold);
      }
      window.addEventListener('scroll', updateNav, { passive: true });
      updateNav();
    }
  }
</script>
