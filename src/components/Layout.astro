---
import type { Locale } from '../i18n/utils';
import SEOHead from './SEOHead.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import '../styles/global.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  image?: string;
  path: string;
  type?: 'website' | 'article';
}

const { locale, title, description, image, path, type } = Astro.props;
const langMap: Record<Locale, string> = { en: 'en', zh: 'zh-Hans', 'zh-tw': 'zh-Hant' };
---

<!doctype html>
<html lang={langMap[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600;700&family=Noto+Serif+TC:wght@400;500;600;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <SEOHead locale={locale} title={title} description={description} image={image} path={path} type={type} />
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <Nav locale={locale} currentPath={path} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
