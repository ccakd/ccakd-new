---
import type { Locale } from '../i18n/utils';
import { t, localePath } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
const year = new Date().getFullYear();
---

<footer class="footer-gold py-8 px-8 text-white/70 text-sm">
  <div class="max-w-[1080px] mx-auto flex flex-col md:flex-row justify-between items-center gap-2">
    <p class="text-white/50">&copy; {year} {strings.footer.copyright}</p>
    <div class="flex items-center gap-6">
      <a href={localePath(locale, '/terms')} class="text-white/70 hover:text-white transition-colors">
        {strings.footer.terms}
      </a>
      <a href="mailto:info@ccakd.ca" class="text-white/70 hover:text-white transition-colors">
        info@ccakd.ca
      </a>
    </div>
  </div>
</footer>

<style>
  .footer-gold {
    background: linear-gradient(135deg, #9A7A45, #B8965C);
    border-top: 3px solid #D04830;
  }
</style>
