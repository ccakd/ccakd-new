---
import type { Locale } from '../i18n/utils';
import { t, localePath } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
const year = new Date().getFullYear();
---

<footer class="border-t border-porcelain-border py-8 px-8 text-porcelain-tertiary text-sm">
  <div class="max-w-[1080px] mx-auto flex flex-col md:flex-row justify-between items-center gap-2">
    <p>&copy; {year} {strings.footer.copyright}</p>
    <div class="flex items-center gap-6">
      <a href={localePath(locale, '/terms')} class="text-porcelain-secondary hover:text-porcelain-text transition-colors">
        {strings.footer.terms}
      </a>
      <a href="mailto:info@ccakd.ca" class="text-porcelain-secondary hover:text-porcelain-text transition-colors">
        info@ccakd.ca
      </a>
    </div>
  </div>
</footer>
