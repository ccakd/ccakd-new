---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';
import Layout from '../../components/Layout.astro';
import Hero from '../../components/Hero.astro';
import AnnouncementCard from '../../components/AnnouncementCard.astro';
import EventCard from '../../components/EventCard.astro';
import ProgramCard from '../../components/ProgramCard.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import SocialLinks from '../../components/SocialLinks.astro';
import type { Locale } from '../../i18n/utils';
import { t, localePath } from '../../i18n/utils';
import { localized } from '../../lib/content';
import { getUpcomingEvents } from '../../lib/hievents';

const locale: Locale = 'en';
const strings = t(locale);

const reader = createReader(process.cwd(), keystaticConfig);

const homepage = await reader.singletons.homepage.read();

const allAnnouncements = await reader.collections.announcements.all();
const sorted = allAnnouncements
  .sort((a, b) => new Date(b.entry.date).getTime() - new Date(a.entry.date).getTime());
const pinnedItems = sorted.filter((a) => a.entry.pinned);
const recentItems = sorted.filter((a) => !a.entry.pinned);
const featured = [...pinnedItems, ...recentItems].slice(0, 3);

const events = await getUpcomingEvents(3);

const allPrograms = await reader.collections.programs.all();
const activePrograms = allPrograms.filter((p) => p.entry.active).slice(0, 3);

const allGalleries = await reader.collections.galleries.all();
const recentGalleries = allGalleries
  .filter((g) => g.entry.cover_image)
  .sort((a, b) => new Date(b.entry.date).getTime() - new Date(a.entry.date).getTime())
  .slice(0, 6)
  .map((g) => ({ slug: g.slug, cover: g.entry.cover_image, title: localized(g.entry as any, 'title', locale) }));
---

<Layout locale={locale} path="/">
  {/* Hero */}
  <Hero
    locale={locale}
    heading={homepage ? (localized(homepage as Record<string, any>, 'hero_heading', locale) || strings.site.title) : strings.site.title}
    ctaLink={homepage?.hero_cta_link || 'https://members.ccakd.ca/en/register'}
    images={(homepage?.hero_images as string[]) || []}
  />

  {/* Announcements */}
  {featured.length > 0 && (
    <section class="py-16 px-8">
      <div class="max-w-[1080px] mx-auto">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="font-display text-2xl font-semibold">{strings.home.announcements}</h2>
          <a href={localePath(locale, '/announcements')} class="text-accent text-[0.84rem] font-medium hover:underline">
            {strings.home.viewAll} &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {featured.map(({ slug, entry }) => (
            <AnnouncementCard locale={locale} slug={slug} entry={entry} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Events */}
  <section class="py-16 px-8 bg-porcelain-section">
    <div class="max-w-[1080px] mx-auto">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="font-display text-2xl font-semibold">{strings.home.upcomingEvents}</h2>
        <a href="https://events.ccakd.ca" class="text-accent text-[0.84rem] font-medium hover:underline">
          {strings.home.seeAllEvents} &rarr;
        </a>
      </div>
      {events.length > 0 ? (
        <div class="flex flex-col gap-3">
          {events.map((event) => <EventCard event={event} locale={locale} />)}
        </div>
      ) : (
        <p class="text-porcelain-secondary">{strings.events.fallback}</p>
      )}
    </div>
  </section>

  {/* Programs */}
  {activePrograms.length > 0 && (
    <section class="py-16 px-8">
      <div class="max-w-[1080px] mx-auto">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="font-display text-2xl font-semibold">{strings.home.programs}</h2>
          <a href={localePath(locale, '/programs')} class="text-accent text-[0.84rem] font-medium hover:underline">
            {strings.home.seeAllPrograms} &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          {activePrograms.map(({ slug, entry }) => (
            <ProgramCard locale={locale} slug={slug} entry={entry} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Gallery */}
  {recentGalleries.length > 0 && (
    <section class="py-16 px-8 bg-porcelain-section">
      <div class="max-w-[1080px] mx-auto">
        <div class="flex items-baseline justify-between mb-8">
          <h2 class="font-display text-2xl font-semibold">{strings.home.gallery}</h2>
          <a href={localePath(locale, '/gallery')} class="text-accent text-[0.84rem] font-medium hover:underline">
            {strings.home.viewAllAlbums} &rarr;
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2.5" style="grid-template-rows: 170px 170px;">
          {recentGalleries.map((g, i) => (
            <a
              href={localePath(locale, `/gallery/${g.slug}`)}
              class:list={[
                'relative rounded-[10px] overflow-hidden bg-porcelain-section bg-cover bg-center transition-all duration-300 hover:opacity-90 hover:scale-[1.01] group',
                i === 0 && 'col-span-2 row-span-2',
              ]}
              style={`background-image:url('${g.cover}')`}
            >
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />
              <span class="absolute bottom-2 left-3 text-white text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity">
                {g.title}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Newsletter */}
  <NewsletterSignup locale={locale} />

  {/* Social Links */}
  <SocialLinks locale={locale} />
</Layout>
